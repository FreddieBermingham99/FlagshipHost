# Copy to .env.local and fill in values. Never commit .env or .env.local.
# See also: .env.local.example

# --- Google Sheets (optional; legacy flagship data source) ---
# GOOGLE_SHEETS_API_KEY=
# GOOGLE_SHEETS_ID=
# GOOGLE_SHEETS_RANGE=Data!A1:Z1000

# --- Stasher PostgreSQL (read-only) ---
# STASHER_DATABASE_READ_URL=postgresql://user:pass@host:5432/dbname
# STASHER_DATABASE_URL=

# FLAGSHIP_PUBLIC_BASE_URL=
# NEXT_PUBLIC_SITE_URL=

# --- Flagship live overrides (optional) ---
# FLAGSHIP_CITY_OVERRIDES_DATABASE_URL=

# --- Short links (TinyURL; optional tuning) ---
# SHORT_LINK_TIMEOUT_MS=8000
# SHORT_LINK_CONCURRENCY=8
# SHORT_LINK_RELAXED_ALIAS=1

# --- Submissions database ---
# SUBMISSIONS_DATABASE_URL=postgresql://user:pass@host:5432/dbname

# --- Dashboard ---
# DASHBOARD_PASSWORD=
# DASHBOARD_AUTH_SECRET=
# DASHBOARD_SESSION_MAX_AGE=86400

# --- Resend ---
# RESEND_API_KEY=
# CAMPAIGN_FROM_EMAIL=

# --- Delivery burst (optional) ---
# GOOGLE_MAPS_API_KEY=          # Geocoding + interactive map (Maps JavaScript API must be enabled)
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=  # Optional override for client map; falls back to GOOGLE_MAPS_API_KEY at build time
# DELIVERY_BURST_DRIVE_FOLDER_ID=  # Drive folder for contractor photo uploads (defaults to GOOGLE_SIGNAGE_DRIVE_FOLDER_ID)

# --- Signage automation ---
# Local: secrets/google-signage-credentials.json (gitignored). Production: use env vars, never commit keys.
# GOOGLE_SIGNAGE_DRIVE_CREDENTIALS_PATH=
# GOOGLE_SIGNAGE_DRIVE_CREDENTIALS_BASE64=
# GOOGLE_SIGNAGE_DRIVE_FOLDER_ID=
# SIGNAGE_DIGEST_PRIMARY_EMAIL=
# SIGNAGE_DIGEST_CRON_SECRET=

# --- Print provider: Solopress ---
# Webhook callback URL Solopress will POST to: https://<your-host>/api/webhooks/solopress
# Run scripts/register-solopress-webhook.mjs once after setting SOLOPRESS_API_KEY and SOLOPRESS_WEBHOOK_SECRET.
# SOLOPRESS_API_KEY=
# SOLOPRESS_BASE_URL=https://api.solopress.com
# SOLOPRESS_AUTH_HEADER=Authorization
# SOLOPRESS_AUTH_PREFIX="Bearer "
# SOLOPRESS_WEBHOOK_SECRET=
# SOLOPRESS_WEBHOOK_ID=
# SOLOPRESS_WEBHOOK_URL=
# SOLOPRESS_ENABLED=true

# --- Print provider: Helloprint ---
# Webhook callback URL Helloprint should POST to:
#   https://<your-host>/api/webhooks/helloprint/<HELLOPRINT_WEBHOOK_TOKEN>
# Choose a long opaque token (≥ 32 random chars). Helloprint callbacks are unsigned;
# the token is the only authentication so guard it like a secret.
# HELLOPRINT_API_KEY=
# HELLOPRINT_BASE_URL=https://api.helloprint.com
# HELLOPRINT_AUTH_HEADER=Authorization
# HELLOPRINT_AUTH_PREFIX="Bearer "
# HELLOPRINT_MODE=sandbox
# HELLOPRINT_WEBHOOK_TOKEN=
# HELLOPRINT_ENABLED=true

# --- Print provider: Cloudprinter ---
# Cloudprinter uses TWO API keys, configured separately in their admin dashboard:
#   1. CloudCore API Interface key  → used for placing orders.       CLOUDPRINTER_API_KEY
#   2. CloudSignal Webhooks key     → embedded in every webhook body. CLOUDPRINTER_WEBHOOK_APIKEY
# Sandbox vs live is a *mode flag on the CloudCore API Interface itself* in their admin,
# so the same base URL is used for both — flipping the mode requires only a key swap.
#
# In the CloudSignal Webhooks config in Cloudprinter admin, set the endpoint to:
#   https://<your-host>/api/webhooks/cloudprinter
# CLOUDPRINTER_API_KEY=
# CLOUDPRINTER_WEBHOOK_APIKEY=
# CLOUDPRINTER_BASE_URL=https://api.cloudprinter.com/cloudcore/1.0
# CLOUDPRINTER_SUPPORT_EMAIL=ops@stasher.com
# CLOUDPRINTER_ENABLED=true
