# --- Google Sheets (optional; legacy flagship data source) ---
# GOOGLE_SHEETS_API_KEY=
# GOOGLE_SHEETS_ID=
# GOOGLE_SHEETS_RANGE=Data!A1:Z1000

# --- Stasher PostgreSQL (read-only) ---
# Prefer a read replica or a DB user with SELECT-only privileges.
# Standard URI: postgresql://user:pass@host:5432/dbname
STASHER_DATABASE_READ_URL=
# Fallback if STASHER_DATABASE_READ_URL is unset:
STASHER_DATABASE_URL=

# Public origin for flagship links in emails / dashboard (no trailing slash).
# If unset: Vercel uses VERCEL_URL; local dev uses http://localhost:3000.
# Set explicitly for a custom production domain, e.g. https://flagship.example.com
# FLAGSHIP_PUBLIC_BASE_URL=
# Optional alternative (also available in the browser):
# NEXT_PUBLIC_SITE_URL=

# --- Dashboard (password gate + signed session cookie) ---
# Shared internal password; compared only on the server (login API).
# DASHBOARD_PASSWORD=
# Secret used only to sign the session cookie (do not reuse the password).
# DASHBOARD_AUTH_SECRET=
# Optional session lifetime in seconds (default 86400).
# DASHBOARD_SESSION_MAX_AGE=86400

# --- Resend (dashboard email campaigns) ---
# API key from Resend; domain must be verified for the From address.
# RESEND_API_KEY=
# Verified sender, e.g. newsletters@yourdomain.com
# CAMPAIGN_FROM_EMAIL=

# --- Scheduled campaigns (optional; writable Postgres, not the read-only Stasher URL) ---
# Stores queued jobs; table `dashboard_campaign_jobs` is created on first use.
# CAMPAIGN_SCHEDULE_DATABASE_URL=
# Vercel Cron calls GET /api/cron/campaign-schedule with header: Authorization: Bearer <secret>
# CRON_SECRET=
